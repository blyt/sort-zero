{
  "manifest_version": 3,
  "name": "Sort Zero",
  "version": "0.1.2",
  "description": "Zero-config bookmark sorting. Keeps your bookmarks sorted. Always.",
  "homepage_url": "https://github.com/blyt/sort-zero",
  "permissions": ["bookmarks"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}

{
  "manifest_version": 3,
  "name": "Sort Zero",
  "version": "0.1.0",
  "description": "Zero-config bookmark sorting. Zero UI. Zero extra permissions. Zero extra features. 70 lines of code.",
  "homepage_url": "https://github.com/blyt/sort-zero",
  "browser_specific_settings": {
    "gecko": {
      "id": "sort-zero@blyt",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": ["bookmarks"],
  "background": {
    "scripts": ["background.js"]
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  }
}
